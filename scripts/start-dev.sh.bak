#!/usr/bin/env bash
# start-dev.sh - Start Climb512 in bind-mounted Next.js development mode
# Usage: ./scripts/start-dev.sh [--build] [--fresh] [--logs] [--guardrails]
#
# Flags:
#   --build       Force rebuild of the dev web image
#   --fresh       Destroy existing data and dev dependency/cache volumes
#   --logs        Tail web logs after starting
#   --guardrails  Start the optional NeMo guardrails service profile

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

BUILD_FLAG=""
FRESH=false
FOLLOW_LOGS=false
GUARDRAILS=false
COMPOSE_FILES=(-f docker-compose.yml -f docker-compose.dev.yml)

for arg in "$@"; do
  case $arg in
    --build) BUILD_FLAG="--build" ;;
    --fresh) FRESH=true ;;
    --logs) FOLLOW_LOGS=true ;;
    --guardrails) GUARDRAILS=true ;;
    *) echo "Unknown flag: $arg"; exit 1 ;;
  esac
done

cd "$REPO_ROOT"

guardrails_mode() {
  if [ ! -f app/.env ]; then
    echo "off"
    return
  fi

  grep -E '^AI_GUARDRAILS_MODE=' app/.env | tail -n 1 | cut -d= -f2- | tr -d '"' | tr -d "'" | tr -d '[:space:]' || echo "off"
}

AI_GUARDRAILS_MODE="$(guardrails_mode)"
COMPOSE_ARGS=("${COMPOSE_FILES[@]}")
if [ "$AI_GUARDRAILS_MODE" = "intake" ]; then
  GUARDRAILS=true
fi

if [ "$GUARDRAILS" = true ]; then
  COMPOSE_ARGS=(--profile guardrails "${COMPOSE_ARGS[@]}")
fi

if ! docker info >/dev/null 2>&1; then
  echo "ERROR: Docker is not running. Start Docker Desktop and try again."
  exit 1
fi

if [ "$FRESH" = true ]; then
  echo "-- Removing existing app data and dev volumes..."
  docker compose "${COMPOSE_ARGS[@]}" down -v 2>/dev/null || true
fi

echo "-- Starting Climb512 in development mode..."
if [ "$GUARDRAILS" = true ]; then
  echo "-- NeMo guardrails profile enabled."
  if [ "$AI_GUARDRAILS_MODE" != "intake" ]; then
    echo "-- Note: app/.env has AI_GUARDRAILS_MODE=$AI_GUARDRAILS_MODE, so web will not route intake through NeMo until it is set to intake."
  fi
else
  echo "-- NeMo guardrails profile disabled. Set AI_GUARDRAILS_MODE=intake or pass --guardrails to start it."
fi
# shellcheck disable=SC2086
docker compose "${COMPOSE_ARGS[@]}" up $BUILD_FLAG -d

echo ""
echo "  Climb512 dev server is running at http://localhost:8080"
echo "  Source changes in ./app are bind-mounted into the web container."
echo ""
echo "  Useful commands:"
echo "    docker compose -f docker-compose.yml -f docker-compose.dev.yml logs web -f"
echo "    docker compose --profile guardrails -f docker-compose.yml -f docker-compose.dev.yml logs guardrails -f"
echo "    ./scripts/stop-dev.sh"
echo "    ./scripts/start.sh --build    # production-style image rebuild"
echo "    ./scripts/start-dev.sh --guardrails --build"
echo ""

if [ "$FOLLOW_LOGS" = true ]; then
  docker compose "${COMPOSE_ARGS[@]}" logs web -f
fi
